    <header class="header home-header peach-bg login-header">
      <div class="container">
      <div class="v-center nest-nav navbar-expand-lg">
<!-- header menu -->
    <style>
  /* Only style the top-level menu items to be black */
  header .header-item .menu-main>li>a:not(.get-started-btn) {
    color: #333 !important;
  }

  /* Top level menu hover effect */
  header .header-item .menu-main>li>a:not(.get-started-btn):hover,
  header .header-item .menu-main>li.menu-item-has-children:hover>a:not(.get-started-btn) {
    color: #ff8e3c !important;
  }

  /* Icon color - black by default */
  header .header-item .menu-main svg path {
    fill: #333 !important;
  }

  /* Icon hover color */
  header .header-item .menu-main>li:hover svg path,
  header .header-item .menu-main>li>a:hover svg path {
    fill: #ff8e3c !important;
  }

  /* Mobile menu trigger */
  header .mobile-menu-trigger span,
  header .mobile-menu-trigger span:before,
  header .mobile-menu-trigger span:after {
    background-color: #333;
  }

  /* Explicitly preserve Get Started button styling */
  header .get-started-btn {
    color: #fff !important;
