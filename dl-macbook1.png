<style>
        /* Badge container to hold both badges */
        .badge-container {
            position: absolute;
            top: 10px;
            right: 25px;
            display: flex;
            flex-direction: row; /* new badge first (on right), then premium badge (on left) */
            gap: 3px; /* small space between badges */
            z-index: 2;
        }
        
        /* Badge styles shared by both Premium and New badges */
        .premium-icon, .new-badge, .free-icon {
            width: auto;
            min-width: auto;
            height: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: bold;
            border-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            padding: 3px 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
            overflow: hidden;
        }
        
        /* Premium icon styles */
        .premium-icon {
            background-color: #ff8e3c;
            color: white;
        }
        
        /* New badge styles */
        .new-badge {
            background-color: #222;
            color: white;
        }
        
        /* Free icon styles */
        .free-icon {
            background-color: #222;
            color: white;
        }
        
        /* Add spacing between SVG icon and text in both badges */
        .premium-icon svg, .new-badge svg, .free-icon svg {
            margin-right: 4px;
        }
        
        /* Make parent container relative for positioning */
        .col-lg-3, .col-sm-3 {
            position: relative;
        }
    </style>
